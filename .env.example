# ====== ntfy Benachrichtigung ======
# Dein privater Push-Kanal. Wähle ein langes, schwer erratbares Topic
# (jeder, der das Topic kennt, kann dir Nachrichten schicken).
# Danach in der ntfy-App (iOS/Android) GENAU dieses Topic abonnieren.
NTFY_TOPIC=fs-oldenburg-aenderMich-7h2kqz9

# Standard-Server. Nur ändern, wenn du einen eigenen ntfy-Server betreibst.
NTFY_SERVER=https://ntfy.sh

# Nur nötig für zugriffsgeschützte / self-hosted Topics (sonst leer lassen):
NTFY_TOKEN=

# ====== Zielzeitraum (Format: YYYY-MM-DD) ======
# Es wird alarmiert, sobald ein verfügbarer Tag in [START..ENDE] fällt.
# (Beispielwerte — deine echten Werte gehören in die .env bzw. bei GitHub Actions in Secrets)
TARGET_START=2026-07-01
TARGET_END=2026-07-15
# Dein bestehender Termin (nur für die Nachricht):
CURRENT_APPOINTMENT=2026-07-20

# ====== Polling ======
# Minuten zwischen den Prüfungen. Minimum 5 (wird hart erzwungen).
POLL_INTERVAL_MINUTES=10
# Zufalls-Schwankung pro Intervall in Sekunden (wirkt natürlicher, schont Server).
POLL_JITTER_SECONDS=45

# ====== Technik (i.d.R. unverändert lassen) ======
HEADLESS=true
SERVICE_ID=301
BASE_URL=https://terminvereinbarung.oldenburg.de/
# Tap-Ziel der Alarm-Push. Deep-Link direkt in die Führerscheinstelle (spart unterwegs einen Klick).
# Leer lassen -> es wird BASE_URL (Startseite) verwendet.
BOOKING_URL=https://terminvereinbarung.oldenburg.de/select2?md=2
NAV_TIMEOUT_MS=25000
# LOG_FILE=logs/monitor.log
# STATE_FILE=state/state.json
